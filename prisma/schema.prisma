generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CASHIER
}

enum ConsoleType {
  PS3
  PS4
  PS5
}

enum ConsoleStatus {
  AVAILABLE
  IN_USE
  NEED_CONFIRMATION
  MAINTENANCE
}

enum PricingType {
  OPEN
  PACKAGE
}

enum TransactionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProductCategory {
  SNACK
  DRINK
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  username     String        @unique
  email        String        @unique
  password     String
  role         Role
  isActive     Boolean       @default(true)
  deletedAt    DateTime?
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
}

model PlayStationUnit {
  id           String        @id @default(uuid()) @db.Uuid
  code         String        @unique
  name         String
  consoleType  ConsoleType
  status       ConsoleStatus @default(AVAILABLE)
  notes        String?
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([consoleType])
  @@index([status])
  @@index([consoleType, status])
}

model RentalRate {
  id           String        @id @default(uuid()) @db.Uuid
  consoleType  ConsoleType   @unique
  hourlyRate   Decimal       @db.Decimal(10, 2)
  isActive     Boolean       @default(true)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([isActive])
}

model RentalPackage {
  id                      String        @id @default(uuid()) @db.Uuid
  name                    String
  consoleType             ConsoleType
  durationMinutes         Int
  price                   Decimal       @db.Decimal(10, 2)
  isActive                Boolean       @default(true)
  transactions            Transaction[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@unique([consoleType, name])
  @@index([consoleType])
  @@index([isActive])
}

model Product {
  id                     String            @id @default(uuid()) @db.Uuid
  code                   String            @unique
  name                   String
  category               ProductCategory
  price                  Decimal           @db.Decimal(10, 2)
  stock                  Int               @default(0)
  isActive               Boolean           @default(true)
  transactionItems       TransactionItem[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([category])
  @@index([isActive])
}

model Transaction {
  id                      String             @id @default(uuid()) @db.Uuid
  invoiceNumber           String             @unique
  pricingType             PricingType
  status                  TransactionStatus  @default(ACTIVE)
  userId                  String             @db.Uuid
  playStationUnitId       String             @db.Uuid
  rentalRateId            String             @db.Uuid
  rentalPackageId         String?            @db.Uuid
  customerName            String?
  startTime               DateTime
  endTime                 DateTime?
  durationMinutes         Int?
  extraTimeMinutes        Int                @default(0)
  hourlyRateSnapshot      Decimal            @db.Decimal(10, 2)
  packageNameSnapshot     String?
  packagePriceSnapshot    Decimal?           @db.Decimal(10, 2)
  packageDurationSnapshot Int?
  packageDurationMinutesSnapshot Int?
  rentalTotal             Int                @default(0)
  productTotal            Int                @default(0)
  grandTotal              Int                @default(0)
  notes                   String?
  user                    User               @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  playStationUnit         PlayStationUnit    @relation(fields: [playStationUnitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  rentalRate              RentalRate         @relation(fields: [rentalRateId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  rentalPackage           RentalPackage?     @relation(fields: [rentalPackageId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items                   TransactionItem[]
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([status])
  @@index([pricingType])
  @@index([userId])
  @@index([playStationUnitId])
  @@index([rentalRateId])
  @@index([rentalPackageId])
  @@index([startTime])
  @@index([endTime])
  @@index([status, startTime])
}

model TransactionItem {
  id                    String           @id @default(uuid()) @db.Uuid
  transactionId         String           @db.Uuid
  productId             String           @db.Uuid
  quantity              Int
  unitPriceSnapshot     Decimal          @db.Decimal(10, 2)
  subtotalSnapshot      Decimal          @db.Decimal(10, 2)
  productNameSnapshot   String
  productCategorySnapshot ProductCategory
  transaction           Transaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product               Product          @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([transactionId])
  @@index([productId])
  @@index([productCategorySnapshot])
}
