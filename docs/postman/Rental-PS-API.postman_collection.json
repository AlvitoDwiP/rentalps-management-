    {
      "name": "Packages",
      "item": [
        {
          "name": "List Packages",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Ambil daftar rental package yang aktif untuk tiap tipe console.",
            "url": {
              "raw": "{{baseUrl}}/api/packages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "packages"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"success true\", () => pm.expect(json.success).to.eql(true));",
                  "pm.test(\"data is array\", () => pm.expect(json.data).to.be.an(\"array\"));",
                  "pm.test(\"minimal 1 package\", () => pm.expect(json.data.length).to.be.at.least(1));",
                  "if (json.data && json.data.length > 0 && json.data[0].id) {",
                  "  pm.collectionVariables.set(\"packageId\", json.data[0].id);",
                  "}"
                ]
