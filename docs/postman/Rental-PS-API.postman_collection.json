    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Active Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Ambil semua transaksi yang masih ACTIVE.",
            "url": {
              "raw": "{{baseUrl}}/api/transactions/active",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "active"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"success true\", () => pm.expect(json.success).to.eql(true));",
                  "pm.test(\"data is array\", () => pm.expect(json.data).to.be.an(\"array\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Start Open Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Memulai transaksi OPEN baru berdasarkan consoleCode.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consoleCode\": \"{{consoleCode}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/open",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "open"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"status 200 or 201\", () => {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test(\"success true\", () => pm.expect(json.success).to.eql(true));",
                  "pm.test(\"transaction id exists\", () => pm.expect(json.data.id).to.exist);",
                  "pm.collectionVariables.set(\"transactionId\", json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Item to Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Menambahkan item produk ke transaksi aktif menggunakan productName dan quantity.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productName\": \"{{productName}}\",\n  \"quantity\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}/items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "{{transactionId}}",
                "items"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"status 200 or 201\", () => {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test(\"success true\", () => pm.expect(json.success).to.eql(true));",
                  "pm.test(\"response data exists\", () => pm.expect(json.data).to.exist);"
                ]
              }
            }
          ]
        },
        {
          "name": "Finish Transaction",
          "request": {
            "method": "POST",
            "header": [],
            "description": "Menyelesaikan transaksi aktif dan menghitung total akhir.",
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}/finish",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "{{transactionId}}",
                "finish"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"success true\", () => pm.expect(json.success).to.eql(true));",
                  "pm.test(\"status completed\", () => pm.expect(json.data.status).to.eql(\"COMPLETED\"));",
                  "pm.test(\"durationMinutes exists\", () => pm.expect(json.data.durationMinutes).to.exist);",
                  "pm.test(\"rentalTotal exists\", () => pm.expect(json.data.rentalTotal).to.exist);",
                  "pm.test(\"productTotal exists\", () => pm.expect(json.data.productTotal).to.exist);",
                  "pm.test(\"grandTotal exists\", () => pm.expect(json.data.grandTotal).to.exist);"
                ]
              }
            }
          ]
        },
        {
          "name": "Start Package Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Memulai transaksi PACKAGE baru. Pastikan packageId sesuai dengan tipe consoleCode. Jika gagal karena package beda tipe, ubah packageId dari response List Packages.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consoleCode\": \"{{consoleCode}}\",\n  \"packageId\": \"{{packageId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/package",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "package"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"status 200 or 201\", () => {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test(\"success true\", () => pm.expect(json.success).to.eql(true));",
                  "pm.test(\"transaction id exists\", () => pm.expect(json.data.id).to.exist);",
                  "pm.collectionVariables.set(\"transactionId\", json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Move Console",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Memindahkan transaksi aktif ke console lain dengan tipe yang sama dan status AVAILABLE.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetConsoleCode\": \"{{targetConsoleCode}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}/console",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "{{transactionId}}",
                "console"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"success true\", () => pm.expect(json.success).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "Finish Package Transaction",
          "request": {
            "method": "POST",
            "header": [],
            "description": "Menutup transactionId hasil Start Package Transaction agar tidak tertinggal ACTIVE.",
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}/finish",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions",
                "{{transactionId}}",
                "finish"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"success true\", () => pm.expect(json.success).to.eql(true));",
                  "pm.test(\"status completed\", () => pm.expect(json.data.status).to.eql(\"COMPLETED\"));"
                ]
              }
            }
          ]
        }
      ]
